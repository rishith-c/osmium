OSMIUM_BASE_PROFILE=full
OSMIUM_HOSTNAME=osmium
OSMIUM_CREATE_DEFAULT_USER=false
OSMIUM_USERNAME=osmium
OSMIUM_PASSWORD=change-me
OSMIUM_ENABLE_DESKTOP_LOGIN=true
OSMIUM_TIMEZONE=America/Los_Angeles
OSMIUM_LOCALE=en_US.UTF-8
OSMIUM_PACKAGES="python3 python3-pip git curl vim htop build-essential ca-certificates"
# Optional Wi-Fi bootstrap:
# OSMIUM_WIFI_SSID=YourNetwork
# OSMIUM_WIFI_PSK=YourPassword
# OSMIUM_WIFI_COUNTRY=US
